{
  "version": 3,
  "pages404": true,
  "appType": "pages",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/index.html",
        "destination": "/",
        "regex": "^/index\\.html(?:/)?$"
      },
      {
        "source": "/login.html",
        "destination": "/login",
        "regex": "^/login\\.html(?:/)?$"
      },
      {
        "source": "/signup.html",
        "destination": "/signup",
        "regex": "^/signup\\.html(?:/)?$"
      },
      {
        "source": "/dashboard.html",
        "destination": "/dashboard",
        "regex": "^/dashboard\\.html(?:/)?$"
      },
      {
        "source": "/shop.html",
        "destination": "/shop",
        "regex": "^/shop\\.html(?:/)?$"
      },
      {
        "source": "/sell.html",
        "destination": "/sell",
        "regex": "^/sell\\.html(?:/)?$"
      },
      {
        "source": "/orders.html",
        "destination": "/orders",
        "regex": "^/orders\\.html(?:/)?$"
      },
      {
        "source": "/profile.html",
        "destination": "/profile",
        "regex": "^/profile\\.html(?:/)?$"
      },
      {
        "source": "/cart.html",
        "destination": "/cart",
        "regex": "^/cart\\.html(?:/)?$"
      },
      {
        "source": "/checkout.html",
        "destination": "/checkout",
        "regex": "^/checkout\\.html(?:/)?$"
      },
      {
        "source": "/seller-dashboard.html",
        "destination": "/seller-dashboard",
        "regex": "^/seller-dashboard\\.html(?:/)?$"
      },
      {
        "source": "/product-detail.html",
        "destination": "/product-detail",
        "regex": "^/product-detail\\.html(?:/)?$"
      },
      {
        "source": "/admin/dashboard.html",
        "destination": "/admin/dashboard",
        "regex": "^/admin/dashboard\\.html(?:/)?$"
      },
      {
        "source": "/admin/manage-users.html",
        "destination": "/admin/manage-users",
        "regex": "^/admin/manage-users\\.html(?:/)?$"
      },
      {
        "source": "/admin/manage-products.html",
        "destination": "/admin/manage-products",
        "regex": "^/admin/manage-products\\.html(?:/)?$"
      },
      {
        "source": "/admin/manage-orders.html",
        "destination": "/admin/manage-orders",
        "regex": "^/admin/manage-orders\\.html(?:/)?$"
      },
      {
        "source": "/admin/earnings.html",
